   "cell_type": "markdown",
   "id": "cd95b084",
   "metadata": {},
   "source": [
    "## Step 2 — Extract Character Crops from Competition Images\n",
    "\n",
    "Extract character crops directly from the competition training images using the ground-truth bounding box annotations. These real-world crops supplement the synthetic and external data with authentic handwriting samples from the target domain.\n",
    "\n",
    "> **Important:** `IMG_DIR` should point to the competition training images directory. Adjust this path for your environment. Several intermediate files generated here (e.g., label maps, crop directories) are fed back into this script as inputs — ensure those paths are also configured correctly."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-06-01T03:59:52.246794Z",
     "iopub.status.busy": "2026-06-01T03:59:52.246202Z",
     "iopub.status.idle": "2026-06-01T03:59:55.670191Z",
     "shell.execute_reply": "2026-06-01T03:59:55.669247Z",
     "shell.execute_reply.started": "2026-06-01T03:59:52.246761Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "🚀 Phase 1: Extracting real crops directly from the 17 Kaggle pages...\n",
      "✅ Successfully extracted 6610 real crops into the Master Dataset.\n",
      "\n",
      "📸 Phase 2: Building Visual Sanity Check Matrix...\n",
      "📦 Zipping the sanity check matrix...\n",
      "✅ Visual Sanity Check Zip created at: /kaggle/working/visual_sanity_check.zip\n"
     ]
    }
   ],
   "source": [
    "import os\n",
    "import glob\n",
    "import json\n",
    "import shutil\n",
    "from PIL import Image\n",
    "\n",
    "# --- CONFIGURATION ---\n",
    "IMG_DIR = \"/kaggle/input/competitions/handwritten-multiscript-character-segmentation-recognition/JU_CMATER/train/images\"\n",
    "JSON_DIR = \"/kaggle/input/competitions/handwritten-multiscript-character-segmentation-recognition/JU_CMATER/train/annotations\"\n",
    "MASTER_DATASET_DIR = \"/kaggle/working/classifier_dataset\"\n",
    "SANITY_CHECK_DIR = \"/kaggle/working/visual_sanity_check\"\n",
    "\n",
    "# Load the label map we generated in the previous script\n",
    "with open('/kaggle/working/hackathon_label_map.json', 'r') as f:\n",
    "    hackathon_label_map = json.load(f)\n",
    "\n",
    "\n",
    "# --- PHASE 1: EXTRACT THE 17 REAL KAGGLE PAGES ---\n",
    "def extract_real_kaggle_crops():\n",
    "    print(\"🚀 Phase 1: Extracting real crops directly from the 17 Kaggle pages...\")\n",
    "    json_files = glob.glob(os.path.join(JSON_DIR, \"*.json\"))\n",
    "    crop_count = 0\n",
    "    \n",
    "    for json_path in json_files:\n",
    "        base_name = os.path.splitext(os.path.basename(json_path))[0]\n",
    "        \n",
    "        # Locate matching image\n",
    "        img_path = None\n",
    "        for ext in ['.jpg', '.JPG', '.png', '.jpeg']:\n",
    "            temp = os.path.join(IMG_DIR, f\"{base_name}{ext}\")\n",
    "            if os.path.exists(temp):\n",
    "                img_path = temp\n",
    "                break\n",
    "        if not img_path: continue\n",
    "            \n",
    "        img = Image.open(img_path).convert('RGB')\n",
    "        \n",
    "        with open(json_path, 'r', encoding='utf-8') as f:\n",
    "            data = json.load(f)\n",
    "            \n",
    "        for i, shape in enumerate(data.get('shapes', [])):\n",
    "            label = shape.get('label')\n",
    "            points = shape.get('points')\n",
    "            if not label or not points or len(points) < 2: continue\n",
    "                \n",
    "            try:\n",
    "                # Translate \"U+XXXX\" to actual character, then to our Hex standard\n",
    "                if label.startswith(\"U+\"):\n",
    "                    actual_char = chr(int(label.replace(\"U+\", \"\"), 16))\n",
    "                else:\n",
    "                    actual_char = label\n",
    "                char_hex = actual_char.encode('utf-8').hex()\n",
    "            except:\n",
    "                continue\n",
    "                \n",
    "            target_dir = os.path.join(MASTER_DATASET_DIR, char_hex)\n",
    "            if not os.path.exists(target_dir):\n",
    "                continue # Skip if it isn't one of our 167 target classes\n",
    "                \n",
    "            # Bounding Box Math with 2px padding for cursive bleed\n",
    "            xs, ys = [p[0] for p in points], [p[1] for p in points]\n",
    "            x1, y1 = max(0, min(xs) - 2), max(0, min(ys) - 2)\n",
    "            x2, y2 = min(img.width, max(xs) + 2), min(img.height, max(ys) + 2)\n",
    "            \n",
    "            if x2 - x1 < 3 or y2 - y1 < 3: continue\n",
    "                \n",
    "            # Crop and Save\n",
    "            crop_img = img.crop((x1, y1, x2, y2))\n",
    "            crop_img.save(os.path.join(target_dir, f\"real_{base_name}_{i}.jpg\"))\n",
    "            crop_count += 1\n",
    "            \n",
    "    print(f\"✅ Successfully extracted {crop_count} real crops into the Master Dataset.\")\n",
    "\n",
    "\n",
    "# --- PHASE 2: VISUAL SANITY CHECK EXPORTER ---\n",
    "def create_visual_sanity_zip():\n",
    "    print(\"\\n📸 Phase 2: Building Visual Sanity Check Matrix...\")\n",
    "    \n",
    "    # Clean old check directory if it exists\n",
    "    if os.path.exists(SANITY_CHECK_DIR):\n",
    "        shutil.rmtree(SANITY_CHECK_DIR)\n",
    "    os.makedirs(SANITY_CHECK_DIR)\n",
    "    \n",
    "    for folder_hex in os.listdir(MASTER_DATASET_DIR):\n",
    "        src_folder = os.path.join(MASTER_DATASET_DIR, folder_hex)\n",
    "        if not os.path.isdir(src_folder): continue\n",
    "            \n",
    "        # Create a readable folder name for you (e.g., \"e0a695_U_0995\")\n",
    "        kaggle_label = hackathon_label_map.get(folder_hex, folder_hex)\n",
    "        safe_label = kaggle_label.replace(\"+\", \"_\").replace(\" \", \"\")\n",
    "        dst_folder = os.path.join(SANITY_CHECK_DIR, f\"{folder_hex[:6]}_{safe_label}\")\n",
    "        os.makedirs(dst_folder, exist_ok=True)\n",
    "        \n",
    "        images = os.listdir(src_folder)\n",
    "        \n",
    "        # Flags to ensure we only grab ONE of each type per class\n",
    "        samples_taken = {'real': False, 'cmater': False, 'emnist': False, 'synthetic': False}\n",
    "        \n",
    "        for img in images:\n",
    "            src_img = os.path.join(src_folder, img)\n",
    "            \n",
    "            if img.startswith('real_') and not samples_taken['real']:\n",
    "                shutil.copy(src_img, os.path.join(dst_folder, img))\n",
    "                samples_taken['real'] = True\n",
    "                \n",
    "            elif img.startswith('cmater_') and not samples_taken['cmater']:\n",
    "                shutil.copy(src_img, os.path.join(dst_folder, img))\n",
    "                samples_taken['cmater'] = True\n",
    "                \n",
    "            elif img.startswith('emnist_') and not samples_taken['emnist']:\n",
    "                shutil.copy(src_img, os.path.join(dst_folder, img))\n",
    "                samples_taken['emnist'] = True\n",
    "                \n",
    "            elif not img.startswith(('real_', 'cmater_', 'emnist_')) and not samples_taken['synthetic']:\n",
    "                # If it has no prefix, it's from our synthetic generator\n",
    "                shutil.copy(src_img, os.path.join(dst_folder, f\"synthetic_sample.jpg\"))\n",
    "                samples_taken['synthetic'] = True\n",
    "                \n",
    "            # Break early if we found one of all 4 types to save time\n",
    "            if all(samples_taken.values()):\n",
    "                break\n",
    "                \n",
    "    print(\"📦 Zipping the sanity check matrix...\")\n",
    "    shutil.make_archive('/kaggle/working/visual_sanity_check', 'zip', SANITY_CHECK_DIR)\n",
    "    print(\"✅ Visual Sanity Check Zip created at: /kaggle/working/visual_sanity_check.zip\")\n",
    "\n",
    "\n",
    "# --- EXECUTE ---\n",
    "extract_real_kaggle_crops()\n",
    "create_visual_sanity_zip()"
   ]
  },
