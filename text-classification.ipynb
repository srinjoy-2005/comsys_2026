   "source": [
    "# --- INTERMEDIATE FILES (generated by earlier cells in this notebook) ---\n",
    "# efficientnet_class_mapping.json  -> saved during training (Step 5)\n",
    "# hackathon_label_map.json          -> saved during crop extraction (Step 2)\n",
    "# intermediate_boxes_expanded.json  -> output of YOLO_training.ipynb (Step 9)\n",
    "# All three must be present in DATA_DIR before running inference.\n",
    "# On Kaggle: if running inference in a new session, add these files as a dataset input.\n",
    "# Locally: ensure DATA_DIR points to the folder containing all three files.\n",
    "\n",
    "print(\"Loading images into memory...\")\n",
    "# CRITICAL: Use the custom tracker instead of standard ImageFolder\n",
    "master_dataset = SourceTrackingImageFolder(MASTER_DATASET_DIR, transform=transform)\n",
    "num_classes = len(master_dataset.classes)\n",
    "print(f\"✅ Locked in exactly {num_classes} active classes!\")\n",
    "\n",
    "class_mapping = {i: c for c, i in master_dataset.class_to_idx.items()}\n",
    "with open('/kaggle/working/efficientnet_class_mapping.json', 'w') as f:\n",
    "    json.dump(class_mapping, f)\n",
    "\n",
    "train_size = int(0.90 * len(master_dataset))\n",
    "val_size = len(master_dataset) - train_size\n",
    "train_data, val_data = random_split(master_dataset, [train_size, val_size])\n",
    "\n",
    "dataloaders = {\n",
    "    'train': DataLoader(train_data, batch_size=256, shuffle=True, num_workers=4, pin_memory=True),\n",
    "    'val': DataLoader(val_data, batch_size=256, shuffle=False, num_workers=4, pin_memory=True)\n",
    "}\n",
    "dataset_sizes = {'train': train_size, 'val': val_size}\n",
    "\n",
    "# --- 4. ARCHITECTURE SURGERY ---\n",
    "model = models.efficientnet_b0(weights='IMAGENET1K_V1')\n",
    "model.features[0][0].stride = (1, 1) # Protect 64x64 resolution\n",
    "model.classifier[1] = nn.Linear(model.classifier[1].in_features, num_classes)\n",
    "model = model.to(device)\n",
    "\n",
    "criterion = nn.CrossEntropyLoss()\n",
    "optimizer = optim.AdamW(model.parameters(), lr=0.001, weight_decay=1e-4)\n",
    "scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode='max', factor=0.5, patience=2)\n",
    "\n",
    "# --- 5. THE TRAINING LOOP ---\n",
    "num_epochs = 15  \n",
    "best_f1 = 0.0 # Tracking by F1 now, not just accuracy!\n",
    "best_model_wts = copy.deepcopy(model.state_dict())\n",
    "\n",
    "print(f\"\\n🔥 Commencing {num_epochs}-Epoch Training Run...\")\n",
    "\n",
    "for epoch in range(num_epochs):\n",
    "    print(f'\\nEpoch {epoch+1}/{num_epochs}')\n",
    "    print('-' * 20)\n",
    "    \n",
    "    epoch_results = {}\n",
    "    \n",
    "    for phase in ['train', 'val']:\n",
    "        model.train() if phase == 'train' else model.eval()\n",
    "\n",
    "        running_loss = 0.0\n",
    "        \n",
    "        # Metric Trackers\n",
    "        all_preds = []\n",
    "        all_labels = []\n",
    "        \n",
    "        # Source Trackers (Only needed for Validation)\n",
    "        src_correct = {'real': 0, 'cmater': 0, 'emnist': 0, 'synthetic': 0}\n",
    "        src_total = {'real': 0, 'cmater': 0, 'emnist': 0, 'synthetic': 0}\n",
    "\n",
    "        pbar = tqdm(dataloaders[phase], desc=f\"{phase.capitalize()} Ep {epoch+1}\", leave=False)\n",
    "        \n",
    "        # Unpack the 3 items (inputs, labels, paths)\n",
    "        for inputs, labels, paths in pbar:\n",
    "            inputs, labels = inputs.to(device, non_blocking=True), labels.to(device, non_blocking=True)\n",
    "            optimizer.zero_grad()\n",
    "            \n",
    "            with torch.set_grad_enabled(phase == 'train'):\n",
    "                outputs = model(inputs)\n",
    "                _, preds = torch.max(outputs, 1)\n",
    "                loss = criterion(outputs, labels)\n",
    "                \n",
    "                if phase == 'train':\n",
    "                    loss.backward()\n",
    "                    optimizer.step()\n",
    "\n",
    "            running_loss += loss.item() * inputs.size(0)\n",
    "            \n",
    "            # Store predictions for Scikit-Learn\n",
    "            all_preds.extend(preds.cpu().numpy())\n",
    "            all_labels.extend(labels.cpu().numpy())\n",
    "            \n",
    "            # Detailed Source Breakdown (Validation Phase Only)\n",
    "            if phase == 'val':\n",
    "                batch_preds = preds.cpu().numpy()\n",
    "                batch_labels = labels.cpu().numpy()\n",
    "                \n",
    "                for i in range(len(paths)):\n",
    "                    file_name = os.path.basename(paths[i])\n",
    "                    is_correct = (batch_preds[i] == batch_labels[i])\n",
    "                    \n",
    "                    if file_name.startswith('real_'):   key = 'real'\n",
    "                    elif file_name.startswith('cmater_'): key = 'cmater'\n",
    "                    elif file_name.startswith('emnist_'): key = 'emnist'\n",
    "                    else: key = 'synthetic'\n",
    "                        \n",
    "                    src_total[key] += 1\n",
    "                    if is_correct: src_correct[key] += 1\n",
    "\n",
    "            pbar.set_postfix({'loss': f'{loss.item():.4f}'})\n",
    "\n",
    "        # --- CALCULATE METRICS ---\n",
    "        epoch_loss = running_loss / dataset_sizes[phase]\n",
    "        \n",
    "        # Macro F1, Precision, and Recall\n",
    "        precision, recall, f1, _ = precision_recall_fscore_support(\n",
    "            all_labels, all_preds, average='macro', zero_division=0\n",
    "        )\n",
    "        accuracy = np.mean(np.array(all_preds) == np.array(all_labels))\n",
    "        \n",
    "        epoch_results[phase] = {\n",
    "            'loss': epoch_loss, 'acc': accuracy, 'f1': f1, 'prec': precision, 'rec': recall\n",
    "        }\n",
    "        \n",
    "        print(f\"{phase.capitalize()} Loss: {epoch_loss:.4f} | Acc: {accuracy:.4f} | F1: {f1:.4f} | Prec: {precision:.4f} | Rec: {recall:.4f}\")\n",
    "\n",
    "        # Print Source Breakdown to Console\n",
    "        if phase == 'val':\n",
    "            print(\"\\n📊 Validation Source Breakdown:\")\n",
    "            for k in src_total.keys():\n",
    "                if src_total[k] > 0:\n",
    "                    src_acc = src_correct[k] / src_total[k]\n",
    "                    print(f\"   - {k.capitalize()}: {src_acc:.4f} ({src_correct[k]}/{src_total[k]})\")\n",
    "            print()\n",
    "\n",
    "            scheduler.step(f1) # Step scheduler based on F1 now\n",
    "            if f1 > best_f1:\n",
    "                best_f1 = f1\n",
    "                best_model_wts = copy.deepcopy(model.state_dict())\n",
    "\n",
    "    # --- 6. DISCORD WEBHOOK ALERTS ---\n",
    "    if (epoch + 1) % 5 == 0 or (epoch + 1) == num_epochs:\n",
    "        val_res = epoch_results['val']\n",
    "        \n",
    "        # Format the Source Breakdown string for Discord\n",
    "        src_msg = \"\"\n",
    "        for k in src_total.keys():\n",
    "            if src_total[k] > 0:\n",
    "                src_msg += f\"- **{k.capitalize()}**: `{src_correct[k]/src_total[k]:.2%}`\\n\"\n",
    "                \n",
    "        notify(\n",
    "            f\"📊 **Training Update (Epoch {epoch+1}/{num_epochs})**\\n\"\n",
    "            f\"**Train** -> Acc: `{epoch_results['train']['acc']:.4f}` | F1: `{epoch_results['train']['f1']:.4f}`\\n\"\n",
    "            f\"**Val** -> Acc: `{val_res['acc']:.4f}` | F1: `{val_res['f1']:.4f}` | Prec: `{val_res['prec']:.4f}` | Rec: `{val_res['rec']:.4f}`\\n\\n\"\n",
    "            f\"🎯 **Validation Source Diagnostics:**\\n{src_msg}\\n\"\n",
    "            f\"🏆 **Current Best Macro F1**: `{best_f1:.4f}`\"\n",
    "        )\n",
    "\n",
    "print(f\"\\n🎉 Stage 2 Training Complete!\")\n",
    "print(f\"🏆 Best Validation Macro F1: {best_f1:.4f}\")\n",
    "notify(f\"🎉 **Stage 2 Training Complete!**\\n🏆 Best Validation Macro F1: `{best_f1:.4f}`\")\n",
    "\n",
    "model.load_state_dict(best_model_wts)\n",
    "torch.save(model.state_dict(), '/kaggle/working/efficientnet_b0_master.pth')\n",
    "print(\"✅ Weights saved to: /kaggle/working/efficientnet_b0_master.pth\")"
   ]
  },
