   "source": [
    "# --- INTERMEDIATE FILES (generated by earlier cells in this notebook) ---\n",
    "# efficientnet_class_mapping.json  -> saved during training (Step 5)\n",
    "# hackathon_label_map.json          -> saved during crop extraction (Step 2)\n",
    "# intermediate_boxes_expanded.json  -> output of YOLO_training.ipynb (Step 9)\n",
    "# All three must be present in DATA_DIR before running inference.\n",
    "# On Kaggle: if running inference in a new session, add these files as a dataset input.\n",
    "# Locally: ensure DATA_DIR points to the folder containing all three files.\n",
    "\n",
    "import os\n",
    "import glob\n",
    "import json\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import pandas as pd\n",
    "from PIL import Image\n",
    "from torchvision import transforms, models\n",
    "from tqdm import tqdm\n",
    "\n",
    "device = torch.device(\"cuda:0\" if torch.cuda.is_available() else \"cpu\")\n",
    "print(f\"🚀 Initializing Final Submission Pipeline on: {device}\")\n",
    "\n",
    "# --- 1. LOAD UPLOADED DATA ---\n",
    "# Replace 'YOUR_UPLOADED_DATASET' with whatever you named your Kaggle Dataset attachment\n",
    "DATA_DIR = '/kaggle/input/datasets/thenamelessmonster/comsys7-test-mapping'\n",
    "TEST_IMG_DIR = '/kaggle/input/competitions/handwritten-multiscript-character-segmentation-recognition/JU_CMATER/test/images'\n",
    "\n",
    "print(\"Loading mappings and intermediate bounding boxes...\")\n",
    "with open(os.path.join(DATA_DIR, 'efficientnet_class_mapping.json'), 'r') as f:\n",
    "    idx_to_hex = {int(k): v for k, v in json.load(f).items()}\n",
    "\n",
    "with open(os.path.join(DATA_DIR, 'hackathon_label_map.json'), 'r') as f:\n",
    "    hex_to_kaggle = json.load(f)\n",
    "\n",
    "with open(os.path.join(DATA_DIR, 'intermediate_boxes_expanded.json'), 'r') as f:\n",
    "    all_page_boxes = json.load(f)\n",
    "\n",
    "# --- 2. LOAD EFFICIENTNET ---\n",
    "print(\"Waking up EfficientNet Brain...\")\n",
    "num_classes = len(idx_to_hex)\n",
    "model = models.efficientnet_b0(weights=None)\n",
    "model.features[0][0].stride = (1, 1) # Resolution protection surgery\n",
    "model.classifier[1] = nn.Linear(model.classifier[1].in_features, num_classes)\n",
    "# --- MODEL PATH ---\n",
    "# 'efficientnet_b0_master.pth' is the checkpoint saved during the training cell above (Step 5).\n",
    "# It is written to /kaggle/working/ automatically. If running inference in a separate session,\n",
    "# you must upload it as a Kaggle dataset or re-run the training cell first.\n",
    "model.load_state_dict(torch.load('efficientnet_b0_master.pth'))\n",
    "model = model.to(device)\n",
    "model.eval()\n",
    "\n",
    "transform = transforms.Compose([\n",
    "    transforms.Resize((64, 64)),\n",
    "    transforms.ToTensor(),\n",
    "    transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225])\n",
    "])\n",
    "\n",
    "# --- 3. INFERENCE & FORMATTING ---\n",
    "submission_data = []\n",
    "print(\"Starting Classification and Formatting...\")\n",
    "\n",
    "for base_name, boxes in tqdm(all_page_boxes.items()):\n",
    "    # Find original test image\n",
    "    img_path = None\n",
    "    for ext in ['.jpg', '.JPG', '.png', '.jpeg']:\n",
    "        temp = os.path.join(TEST_IMG_DIR, f\"{base_name}{ext}\")\n",
    "        if os.path.exists(temp):\n",
    "            img_path = temp\n",
    "            break\n",
    "            \n",
    "    pil_img = Image.open(img_path).convert('RGB')\n",
    "    crop_tensors = []\n",
    "    valid_boxes = []\n",
    "\n",
    "    # Physically crop every bounding box YOLO found\n",
    "    for box in boxes:\n",
    "        x1, y1, x2, y2 = box\n",
    "        \n",
    "        # 2-pixel pad to capture cursive bleed\n",
    "        cx1, cy1 = max(0, x1 - 2), max(0, y1 - 2)\n",
    "        cx2, cy2 = min(pil_img.width, x2 + 2), min(pil_img.height, y2 + 2)\n",
    "\n",
    "        if cx2 - cx1 < 3 or cy2 - cy1 < 3: continue\n",
    "\n",
    "        crop = pil_img.crop((cx1, cy1, cx2, cy2))\n",
    "        crop_tensors.append(transform(crop))\n",
    "        \n",
    "        # Keep the ORIGINAL unpadded box for the submission CSV coordinates\n",
    "        valid_boxes.append([float(x1), float(y1), float(x2), float(y2)])\n",
    "\n",
    "    bengali_votes = 0\n",
    "    english_votes = 0\n",
    "    character_predictions = []\n",
    "\n",
    "    if crop_tensors:\n",
    "        # GPU Batched Inference\n",
    "        batch_tensor = torch.stack(crop_tensors).to(device)\n",
    "        \n",
    "        # Chunking prevents VRAM overload if a page has 2000+ boxes\n",
    "        preds = []\n",
    "        chunk_size = 512\n",
    "        with torch.no_grad():\n",
    "            for i in range(0, batch_tensor.size(0), chunk_size):\n",
    "                chunk = batch_tensor[i:i+chunk_size]\n",
    "                outputs = model(chunk)\n",
    "                _, chunk_preds = torch.max(outputs, 1)\n",
    "                preds.extend(chunk_preds.cpu().numpy())\n",
    "\n",
    "        # Map predictions back to Hackathon string format\n",
    "        for i, pred_idx in enumerate(preds):\n",
    "            char_hex = idx_to_hex[pred_idx]\n",
    "            kaggle_label = hex_to_kaggle.get(char_hex, \"Unknown\")\n",
    "\n",
    "            if kaggle_label.startswith('U+09'): # 09 is the Bengali unicode block\n",
    "                bengali_votes += 1\n",
    "            else:\n",
    "                english_votes += 1\n",
    "\n",
    "            char_dict = {\n",
    "                \"unicode_value\": kaggle_label,\n",
    "                \"bbox\": valid_boxes[i]\n",
    "            }\n",
    "            # Use json.dumps to stringify the inner dictionary\n",
    "            character_predictions.append(json.dumps(char_dict, separators=(',', ':')))\n",
    "\n",
    "    # Calculate overall page script\n",
    "    script_id = 1 if bengali_votes > english_votes else 0\n",
    "\n",
    "    # Build the final Kaggle array string format\n",
    "    if len(character_predictions) > 0:\n",
    "        chars_joined = \",\".join(character_predictions)\n",
    "        final_pred_string = f'[\"script\":{script_id},{chars_joined}]'\n",
    "    else:\n",
    "        final_pred_string = f'[\"script\":{script_id}]'\n",
    "\n",
    "    submission_data.append({\n",
    "        \"page_id\": base_name,\n",
    "        \"predictions\": final_pred_string\n",
    "    })\n",
    "\n",
    "# --- 4. EXPORT ---\n",
    "df = pd.DataFrame(submission_data)\n",
    "df = df.sort_values(by=\"page_id\")\n",
    "submission_path = '/kaggle/working/submission_expanded.csv'\n",
    "df.to_csv(submission_path, index=False)\n",
    "\n",
    "print(f\"\\n🎯 Pipeline complete! Your hackathon file is saved to: {submission_path}\")"
   ]
  },
