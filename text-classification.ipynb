   "source": [
    "# NOTE: This cell generates visual debug overlays for each page in the submission CSV.\n",
    "# It is for inspection only and is NOT required for the final competition submission.\n",
    "# Output images are zipped to /kaggle/working/visual_predictions.zip for download.\n",
    "\n",
    "import os\n",
    "import json\n",
    "import pandas as pd\n",
    "from PIL import Image, ImageDraw, ImageFont, ImageOps\n",
    "import shutil\n",
    "import re # Added for bulletproof string extraction\n",
    "\n",
    "# --- CONFIGURATION ---\n",
    "TEST_IMG_DIR = '/kaggle/input/competitions/handwritten-multiscript-character-segmentation-recognition/JU_CMATER/test/images'\n",
    "SUBMISSION_CSV = '/kaggle/working/submission_expanded.csv'\n",
    "DEBUG_OUTPUT_DIR = '/kaggle/working/visual_predictions'\n",
    "# FONT_PATH: Requires the 'fonts-syntheticdatageneration' Kaggle dataset (same one used by\n",
    "# kaggle_text_classifier_data_generation.py). Add it via '+ Add Data' on Kaggle, or\n",
    "# update the path to any Bengali-supporting TTF font on your local machine.\n",
    "FONT_PATH = '/kaggle/input/datasets/thenamelessmonster/fonts-syntheticdatageneration/fonts/bengali/BalooDa2-Regular.ttf'\n",
    "\n",
    "if os.path.exists(DEBUG_OUTPUT_DIR):\n",
    "    shutil.rmtree(DEBUG_OUTPUT_DIR)\n",
    "os.makedirs(DEBUG_OUTPUT_DIR)\n",
    "\n",
    "print(\"🔍 Starting Bulletproof Visual Debugger...\")\n",
    "\n",
    "# 1. Load the CSV (Force Pandas to read page_id as a string!)\n",
    "df = pd.read_csv(SUBMISSION_CSV, dtype={'page_id': str})\n",
    "\n",
    "try:\n",
    "    font = ImageFont.truetype(FONT_PATH, 24)\n",
    "except Exception as e:\n",
    "    print(f\"⚠️ Font error: {e}. Falling back to default font.\")\n",
    "    font = ImageFont.load_default()\n",
    "\n",
    "# 3. Process each page\n",
    "for index, row in df.iterrows():\n",
    "    # Force 3-digit padding (e.g. '1' becomes '001')\n",
    "    page_id = str(row['page_id']).zfill(3)\n",
    "    pred_string = str(row['predictions'])\n",
    "    \n",
    "    img_path = None\n",
    "    for ext in ['.jpg', '.JPG', '.png', '.jpeg']:\n",
    "        temp = os.path.join(TEST_IMG_DIR, f\"{page_id}{ext}\")\n",
    "        if os.path.exists(temp):\n",
    "            img_path = temp\n",
    "            break\n",
    "            \n",
    "    if not img_path:\n",
    "        print(f\"Skipping {page_id}: Image not found.\")\n",
    "        continue\n",
    "        \n",
    "    img = Image.open(img_path).convert('RGB')\n",
    "    img = ImageOps.exif_transpose(img)\n",
    "    draw = ImageDraw.Draw(img)\n",
    "    \n",
    "    # ---------------------------------------------------------\n",
    "    # THE FIX: Use Regex to safely extract boxes and unicodes\n",
    "    # ---------------------------------------------------------\n",
    "    # This grabs anything between \"bbox\":[ and ]\n",
    "    bboxes_str = re.findall(r'\"bbox\":\\s*\\[(.*?)\\]', pred_string)\n",
    "    # This grabs anything between \"unicode_value\":\" and \"\n",
    "    unicodes = re.findall(r'\"unicode_value\":\\s*\"(.*?)\"', pred_string)\n",
    "    \n",
    "    # Draw the predictions\n",
    "    # Draw the predictions\n",
    "    for u_val, b_str in zip(unicodes, bboxes_str):\n",
    "        try:\n",
    "            # Convert string \"x1, y1, x2, y2\" into a float list\n",
    "            x1, y1, x2, y2 = [float(n) for n in b_str.split(',')]\n",
    "            \n",
    "            # THE FIX: Safely extract just the hex numbers (e.g., '09AA' and '09BE')\n",
    "            if u_val.startswith(\"U+\"):\n",
    "                hex_codes = re.findall(r'U\\+([0-9A-Fa-f]+)', u_val)\n",
    "                actual_char = \"\".join([chr(int(h, 16)) for h in hex_codes])\n",
    "            else:\n",
    "                actual_char = u_val\n",
    "        except Exception as e:\n",
    "            # We print the error now instead of silently skipping!\n",
    "            print(f\"Skipped rendering box due to error: {e}\")\n",
    "            continue\n",
    "\n",
    "        # Draw Bounding Box (Green)\n",
    "        draw.rectangle([x1, y1, x2, y2], outline=\"green\", width=2)\n",
    "        \n",
    "        # Draw Text Background\n",
    "        text_bbox = draw.textbbox((x1, y1 - 30), actual_char, font=font)\n",
    "        draw.rectangle(text_bbox, fill=\"black\")\n",
    "        \n",
    "        # Draw Text (White)\n",
    "        draw.text((x1, y1 - 30), actual_char, font=font, fill=\"white\")\n",
    "        \n",
    "    output_path = os.path.join(DEBUG_OUTPUT_DIR, f\"pred_{page_id}.jpg\")\n",
    "    img.save(output_path)\n",
    "    print(f\"✅ Generated visualization for Page {page_id} ({len(unicodes)} characters drawn)\")\n",
    "\n",
    "print(\"\\n📦 Zipping images for download...\")\n",
    "shutil.make_archive('/kaggle/working/visual_predictions', 'zip', DEBUG_OUTPUT_DIR)\n",
    "print(\"🎯 Done! Download visual_predictions.zip from the right-hand panel.\")"
   ]
  },
